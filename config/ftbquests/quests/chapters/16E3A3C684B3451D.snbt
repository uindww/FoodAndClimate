	quests: [
		{
			description: [
				"耕地ブロックに骨粉などの肥料をやると､｢施肥された耕地ブロック｣になります｡"
				"｢施肥された耕地ブロック｣にHeatAndClimateのWILD作物を植えると､育った時に変異して同じ種の別の作物に進化します｡（すでに変異した後の作物は変異しません）"
				"生えている草に対してクワを使う事でも、施肥された耕地ブロックを作れます。序盤の資源不足の時にはこの手も有効でしょう。"
				""
				"レア度が高い作物が必ずしも優れているわけではなく、WILD種にしかできないこともあります。"
				"特に「変異を行える」というのはWILD種の大きな強みなので、種全部を変異させるのはおすすめしません。"
			]
			icon: "minecraft:bone_meal"
			id: "4C3A61EDC93209C3"
			rewards: [{
				count: 5
				id: "73F1CB0D1E724673"
				item: "minecraft:bone_meal"
				type: "item"
			}]
			tasks: [{
				advancement: "dcs_climate:main/fertilizer"
				criterion: ""
				id: "62BFA88692FF3282"
				type: "advancement"
			}]
			title: "耕地に肥料をやる"
			x: -2.0d
			y: -2.5d
		}
		{
			description: [
				"土を真ん中に､周りにボート型に紙を5つ並べると､｢育苗ポット｣ができます｡"
				"HeatAndClimateの農作物と育苗ポットをクラフトすると、農作物を種にできます。"
				"沢山植えたい時に便利です。育苗ポットは使ってもなくなりません。"
			]
			id: "7D07DB4B43DCF168"
			rewards: [{
				count: 5
				id: "41098DB94635E17E"
				item: "minecraft:bone_meal"
				type: "item"
			}]
			tasks: [{
				id: "70FF8825CC99EE94"
				item: "dcs_climate:main/seeding_pot"
				type: "item"
			}]
			x: -3.0d
			y: -2.5d
		}
		{
			description: [
				"HeatAndClimateの野菜類（畑に植えるもの）は一年を通して収穫できますが、木になるタイプの果物は特定の季節でないと収穫できないものが多いです。"
				"幸い旬の季節にはほぼ取り放題とも言える速度で収穫できるので、一年分貯めておきましょう。(季節はゲーム内60日で、各四季に前期後期があります)"
			]
			id: "4311145BF30A613E"
			rewards: [{
				count: 8
				id: "5111ACB80413FCC7"
				item: "minecraft:glow_berries"
				type: "item"
			}]
			subtitle: "果物には旬がある"
			tasks: [{
				advancement: "dcs_climate:main/tree_crops"
				criterion: ""
				id: "2D0C021D8712E434"
				type: "advancement"
			}]
			title: "旬の果物"
			x: -1.0d
			y: -2.5d
		}
		{
			description: [
				"HeatAndClimateの作物の種がどうしても見つからない時の手段として、「種袋」があります。"
				"色のエキスと種3つから作れて、色に応じた作物のWILD種の中からランダムで1個種が手に入ります。"
				"このクエストの報酬でもあるので必要に応じて使ってみてください。"
			]
			id: "2C4035CB0AA6F2AF"
			rewards: [{
				exclude_from_claim_all: true
				id: "5F66CE27ED724BA7"
				table_id: 6657538831694986129L
				type: "choice"
			}]
			subtitle: "どうしても種が見つからない時に"
			tasks: [{
				id: "22EB6100C9D3FF14"
				title: "種袋"
				type: "checkmark"
			}]
			x: -3.0d
			y: -1.5d
		}
		{
			description: [
				"ただのバニラの草(回収にはハサミが必要です)をクラフトすることで｢干し草｣を得られます｡"
				"結構色々なものの材料になるので入手してみましょう｡"
			]
			id: "53C9BDD0145E7840"
			rewards: [{
